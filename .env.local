# Connect to a local node.
#
# For more information on how to use .env files and environment variables
# consult the Configuration section in the README.

SAS_EXPRESS_BIND_HOST=0.0.0.0

# Port exposed by the container
SAS_EXPRESS_PORT=8089

SAS_SUBSTRATE_WS_URL=ws://127.0.0.1:9944

SAS_LOG_JSON=true
SAS_LOG_LEVEL=debug

# SAS_SUBSTRATE_TYPES_BUNDLE=
# SAS_SUBSTRATE_TYPES_CHAIN=Development
# SAS_SUBSTRATE_TYPES_SPEC=bifrost

SAS_SUBSTRATE_TYPES=../../types-definition.json